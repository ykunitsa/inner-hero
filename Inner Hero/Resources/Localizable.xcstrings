    "predefined.exposure.cafe_introduction.step1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to a cafe or coworking space"
          }
        }
      }
    },
    "predefined.exposure.cafe_introduction.step2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose someone who is not busy"
          }
        }
      }
    },
    "predefined.exposure.cafe_introduction.step3" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Approach with a smile"
          }
        }
      }
    },
