      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start with a simple question (for example, about Wi-Fi)"
          }
        }
      }
    },
    "predefined.exposure.cafe_introduction.step5" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the person is open to conversation, introduce yourself"
          }
        }
      }
    },
