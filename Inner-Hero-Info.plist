<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The PMR voice has to keep running once the screen goes dark (spec §5):
	     the exercise is done with eyes closed, so a dark screen is the normal
	     case, not the exception. Paired with the .playback audio session in
	     Core/Utilities/AudioSession.swift. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- The one external entry point (§11.7): widgets and notifications both
	     open the app through innerhero:// URLs. See Core/Navigation/DeepLink.swift.
	     Not declared for inbound links from anywhere else — nothing outside this
	     app has a reason to drive it. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>wrongteam.Inner-Hero.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>innerhero</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
